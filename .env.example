# Copy to .env or .env.production, then run: npm run build
# Stripe Dashboard → Developers → API keys → Publishable key

VITE_STRIPE_PUBLISHABLE_KEY=pk_live_or_pk_test_replace_me

# Backend base URL (no trailing slash). Production example:
VITE_API_URL=https://maxbitcore.com/server

# If you omit VITE_API_URL, production builds fall back to ${origin}/server (same host as the site).

# Shared secret: admin panel loads Stripe-paid orders from the Node server and can PATCH/DELETE them.
# Must match ADMIN_ORDERS_SECRET in server/.env (same random string).
# VITE_ADMIN_ORDERS_SECRET=your_long_random_string

# --- server/.env on the host (do not commit) ---
# After one-time Checkout payment, create a Stripe Invoice (hosted PDF + customer email). Default: enabled.
# STRIPE_CHECKOUT_INVOICE=false
# Optional text on the invoice:
# STRIPE_INVOICE_DESCRIPTION=MaxBit equipment order
# STRIPE_INVOICE_FOOTER=Thank you for your purchase.
# Optional JSON array → Stripe Invoice custom_fields (max 4; name ≤40, value ≤140 chars each):
# STRIPE_INVOICE_CUSTOM_FIELDS=[{"name":"Note","value":"Built-to-order; SN assigned at ship"}]

# Serial pool (server/data/serial-pool.json) — free SNs per site product id; reserved at Checkout, returned if session expires.
# SERIAL_POOL_ENABLED=false
# Every cart line must have pool stock (otherwise checkout 409):
# SERIAL_POOL_STRICT=true
# Reservation TTL before SN returns to pool (ms). Default 5400000 (90 min).
# SERIAL_RESERVATION_TTL_MS=5400000
# Stripe webhook: add event checkout.session.expired so abandoned Checkouts release SNs promptly.

# CLIENT_URL must list every frontend origin the browser may send (or API calls fail from CORS):
# CLIENT_URL=https://maxbitcore.com,https://www.maxbitcore.com

# Protects GET /shop-orders and POST …/fulfillment, POST …/delete (must match VITE_ADMIN_ORDERS_SECRET):
# ADMIN_ORDERS_SECRET=your_long_random_string

# After payment, Node POSTs sold product IDs to mark-products-sold.php — required for automatic "Sold Out".
# Set MARK_PRODUCTS_SOLD_SECRET on Node (if missing, sold PCs stay "In Stock"). Tries www + non-www URL.
# Use the SAME secret on Node and PHP:
#   Node (cPanel env): MARK_PRODUCTS_SOLD_SECRET + MARK_PRODUCTS_SOLD_URL
#   PHP: getenv MARK_PRODUCTS_SOLD_SECRET OR copy api/mark_products_sold.local.example.php → mark_products_sold.local.php and return the secret.
# MARK_PRODUCTS_SOLD_SECRET=another_long_random_string
# MARK_PRODUCTS_SOLD_URL=https://www.maxbitcore.com/api/mark-products-sold.php

# Checkout address autocomplete uses Photon (OpenStreetMap) — no API key required.

# --- Paid order emails (after successful Stripe payment) ---
# Browser POSTs JSON to notify-order-paid.php; PHP mail() sends:
#   - full order to info@maxbitcore.com
#   - confirmation to the customer (same script)
# Upload api/notify-order-paid.php and ensure hosting mail/SMTP reaches Gmail/Workspace.
# Optional shared secret (must match MAXBIT_ORDER_NOTIFY_SECRET in PHP if set):
# VITE_ORDER_NOTIFY_SECRET=your_random_string
# To disable these emails entirely:
# VITE_ORDER_NOTIFY_URL=off
# Custom URL (if script is not at default path):
# VITE_ORDER_NOTIFY_URL=https://www.maxbitcore.com/api/notify-order-paid.php
#
# If no emails arrive: (1) DevTools → Network → notify-order-paid.php — not 403/forbidden (secret mismatch),
# not 500/smtp_failed. (2) Prefer SMTP: in api/ run `composer install`, copy order_mail_config.example.php →
# order_mail_config.php, set mailbox info@maxbitcore.com + cPanel SMTP host/port. Deploy api/vendor/ to the host.
# (3) VITE_ORDER_NOTIFY_URL must not be "off". Rebuild frontend after changing VITE_*.
#
# Node (webhook) also POSTs the same script if the customer closes the tab before the browser can notify.
# Set the SAME secret as in PHP (order_mail_config: MAXBIT_ORDER_NOTIFY_SECRET) or leave both empty on dev:
# MAXBIT_ORDER_NOTIFY_SECRET=your_random_string
# ORDER_NOTIFY_PAID_URL=https://www.maxbitcore.com/api/notify-order-paid.php
# ORDER_NOTIFY_FROM_WEBHOOK=false   # set to false only if you get duplicate shop emails
#
# Sold Out not updating: redeploy Node after server changes; MARK_PRODUCTS_SOLD_SECRET must match PHP;
# product id in cart must match JSON "id" in products.json; check Node logs for mark-products-sold warnings.
